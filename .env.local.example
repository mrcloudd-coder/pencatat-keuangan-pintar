# Supabase (Settings > API di dashboard Supabase)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxx

# Gemini API key (aistudio.google.com > Get API Key)
# --- Opsi 1: satu API key saja ---
GEMINI_API_KEY=AQ.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Opsi 2: lebih dari satu API key (auto-switch kalau satu kena limit) ---
# Kalau diisi, GEMINI_API_KEYS akan dipakai duluan (GEMINI_API_KEY diabaikan).
# Pisahkan tiap key dengan koma, TANPA spasi setelah koma.
# GEMINI_API_KEYS=key_pertama,key_kedua,key_ketiga
